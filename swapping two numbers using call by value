#include <stdio.h>

int input();
void swap(int a, int b);
void output(int a,int b);

int main() {
int a,b;

printf("enter the values of a:\n");
a=input();
printf("enter the values of b:\n");
b=input();
printf("numbers before swapping: %d %d\n",a,b);
swap(a,b);
printf("numbers after swapping are %d %d",a,b);
return (a,b);
return 0;

int input(){
    int value;
    scanf("%d",&value);
    return value;
}
void swap(int a, int b){
    int temp =a;
    a=b;
    b=temp;
    output(a,b);
}
void output(int a, int b){
    printf("numbers swapped are %d %d",a,b);
}
